APP_ORDER_BRANCH=9999
APP_ORDER_LETTER=X
APP_CUSTOMER_ACCOUNT=
APP_VENDOR_ID=9999
APP_UNEGOCIO=1
APP_PRICE_LIST_ID=1
APP_CLASS_PRICE=1
APP_SALE_REASON_ID=1
APP_STOCK_REASON_ID=1
APP_DOCUMENT_TYPE=1
APP_IVA_CONDITION=1
APP_PAYMENT_CONDITION=1
